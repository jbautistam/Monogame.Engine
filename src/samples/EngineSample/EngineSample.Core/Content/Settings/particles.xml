fireProfile.AddModifier(new DragModifier(0.95f));
fireProfile.AddModifier(new ScaleOverLifetimeModifier(1f, 0.1f)); // Se encoge
fireProfile.AddModifier(new AlphaOverLifetimeModifier(1f, 0f));
