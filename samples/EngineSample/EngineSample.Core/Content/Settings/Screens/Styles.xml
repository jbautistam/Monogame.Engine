<?xml version="1.0" encoding="utf-8" ?>
<Styles>
	<!-- Estilos de etiquetas -->
	<Style Name = "HeaderStyle" Type = "Normal" Color = "Red" />
	<Style Name = "TextStyle" Type = "Normal" Color = "White" />
	<!-- Estilo de botones -->
	<Style Name = "ButtonStyle">
		<Normal>
			<Background Texture = "Tiles/BlockA4" Region = "" />
			<Text Font="Fonts/Hud" Color="Green" Opacity ="1" Rotation = "0" />
		</Normal>
		<Selected>
			<Background Texture = "Tiles/BlockA0" Region = "" />
			<Text Font="Fonts/Hud" Color="Navy" Opacity ="1" Rotation = "0" />
		</Selected>
		<Hover>
			<Background Texture = "Tiles/BlockB0" Region = "" />
			<Text Font="Fonts/Hud" Color="White" Opacity ="1" Rotation = "0" />
		</Hover>
		<Disabled>
			<Background Texture = "Tiles/BlockA3" Region = "" />
			<Text Font="Fonts/Hud" Color="Gray" Opacity ="1" Rotation = "0" />
		</Disabled>
	</Style>
	<!-- Estilo de menú -->
	<Style Name = "MenuStyle" Type = "Normal" Color = "Green">
		<Background Texture = "sprites/gradient" Region = "" />
	</Style>
	<!-- Estilo de las opciones de menú -->
	<Style Name = "MenuOptionsStyle">
		<Normal>
			<Background Texture = "Tiles/BlockA4" Region = "" />
			<Text Font="Fonts/Hud" Color="Green" Opacity ="1" Rotation = "0" />
		</Normal>
		<Selected>
			<Background Texture = "Tiles/BlockA0" Region = "" />
			<Text Font="Fonts/Hud" Color="Navy" Opacity ="1" Rotation = "0" />
		</Selected>
		<Hover>
			<Background Texture = "Tiles/BlockB0" Region = "" />
			<Text Font="Fonts/Hud" Color="White" Opacity ="1" Rotation = "0" />
		</Hover>
		<Disabled>
			<Background Texture = "Tiles/BlockA3" Region = "" />
			<Text Font="Fonts/Hud" Color="Gray" Opacity ="1" Rotation = "0" />
		</Disabled>
	</Style>
</Styles>